# Inventory — Environment Variables
# Copy to .env for local development. Azure App Service reads from Configuration blade.

# Azure SQL Server connection string
# Format: sqlserver://HOST:1433;database=DATABASE;user=USER;password=PASSWORD;encrypt=true;trustServerCertificate=true
DATABASE_URL=sqlserver://localhost:1433;database=Inventory;user=sa;password=YourStrong!Passw0rd;encrypt=true;trustServerCertificate=true

# Session token signing key
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string

# Anthropic API key — required for AI column mapping, allergen detection, unit parsing
ANTHROPIC_API_KEY=sk-ant-your-key

# USDA FoodData Central API key — free from https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=your-usda-key

# CORS origins — comma-separated, no trailing slashes
# Dev: http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Server port — Azure App Service sets this automatically
PORT=8080

# Demo mode — set to "true" to enable automatic authentication
DEMO_MODE=false
